{
  "TestConfiguration": {
    "Api": {
      "BaseUrl": "http://localhost:3000",
      "Timeout": 30,
      "RetryCount": 3
    },
    "UI": {
      "BaseUrl": "http://localhost:8080",
      "Browser": "chromium",
      "Headless": true,
      "ImplicitWait": 10,
      "PageLoadTimeout": 30,
      "ScreenshotOnFailure": true
    },
    "Database": {
      "Host": "localhost",
      "Port": 5432,
      "Database": "testshop",
      "Username": "testuser",
      "Password": "testpass",
      "ConnectionTimeout": 10
    },
    "TestData": {
      "ProductPrice": 1000.00,
      "ExpectedDiscountPercentage": 25,
      "ExpectedDiscountAmount": 250.00,
      "ExpectedFinalPrice": 750.00
    },
    "Cleanup": {
      "Enabled": true,
      "DeleteTestOrders": true,
      "DeleteTestPromotions": true
    }
  }
}
